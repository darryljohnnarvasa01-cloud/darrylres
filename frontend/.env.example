VITE_API_BASE_URL=
VITE_REVERB_ENABLED=true
VITE_REVERB_APP_KEY=rescuelink-key
VITE_REVERB_PORT=8080
VITE_REVERB_TLS=false

# Production can also set the API URL at runtime in `public/config.js`,
# which lets a Cloudflare Pages frontend keep the same build while the
# backend domain changes.
#
# window.__RESCUELINK_CONFIG__ = { apiBaseUrl: 'https://api.example.com' }
#
# Supabase browser config is served by /api/v1/public/config
# from backend environment variables:
# SUPABASE_URL, SUPABASE_ANON_KEY.
