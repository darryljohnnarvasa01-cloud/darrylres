APP_NAME=RescueLink
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Manila
APP_URL=https://api.your-cloudflare-domain.example
FORCE_HTTPS=true
FRONTEND_URL=https://your-cloudflare-domain.example
CLOUDFLARE_FRONTEND_URL=https://your-cloudflare-domain.example
CORS_ALLOWED_ORIGINS=https://your-cloudflare-domain.example
CORS_ALLOWED_ORIGIN_PATTERNS=
SANCTUM_STATEFUL_DOMAINS=
SANCTUM_UPDATE_LAST_USED_AT=false
SANCTUM_TOKEN_CACHE_TTL=30
GUEST_REPORT_LIMIT=10

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=aws-0-your-region.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=replace-with-supabase-database-password
DB_SCHEMA=public
DB_SSLMODE=require
DB_PERSISTENT=false

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

GOOGLE_MAPS_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DRIVE_CLIENT_CONFIG=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_BACKUP_FOLDER_ID=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
GOVERNMENT_ID_DISK=supabase_private
INCIDENT_MEDIA_DISK=supabase_public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SUPABASE_STORAGE_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_STORAGE_ACCESS_KEY_ID=replace-with-supabase-storage-access-key-id
SUPABASE_STORAGE_SECRET_ACCESS_KEY=replace-with-supabase-storage-secret-access-key
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_PUBLIC_BUCKET=incident-media
SUPABASE_STORAGE_PRIVATE_BUCKET=government-ids
SUPABASE_STORAGE_PUBLIC_URL=https://your-project-ref.supabase.co/storage/v1/object/public/incident-media
SUPABASE_STORAGE_USE_PATH_STYLE_ENDPOINT=true

REVERB_APP_ID=rescuelink
REVERB_APP_KEY=rescuelink-key
REVERB_APP_SECRET=replace-with-random-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
