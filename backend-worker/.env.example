# Copy values from the Laravel backend where appropriate.
# Do not commit real secrets.

APP_NAME=RescueLink
APP_ENV=local
APP_KEY=base64-or-random-secret-for-guest-hashing
FRONTEND_URL=https://rescuelink.darryljohnnarvasa01.workers.dev

# Free option 1 (no email, no domain): show verify/reset links on screen
EXPOSE_AUTH_LINKS=true

# Free option 2: Resend.com free tier (3,000 emails/month)
# Sign up at https://resend.com, create an API key, then:
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM_ADDRESS=onboarding@resend.dev
# Note: onboarding@resend.dev only delivers to the email you used to sign up for Resend.

# Paid/custom-domain option: Cloudflare Email Sending on your own domain
# MAIL_FROM_ADDRESS=noreply@your-domain.com

MAIL_FROM_NAME=RescueLink
PASSWORD_RESET_EXPIRES_MINUTES=60
GUEST_REPORT_LIMIT=10
DEFAULT_EMERGENCY_HOTLINE=0966-123-4567
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://rescuelink.darryljohnnarvasa01.workers.dev,https://darrylres.darryljohnnarvasa01.workers.dev

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_MAPS_API_KEY=
